# Environment Variables Template for DOER Backend
# Copy this file to .env and fill in your values

# Supabase Project URL (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (public, safe for client-side)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (private, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Project Reference ID (from Supabase Dashboard URL)
SUPABASE_PROJECT_REF=your-project-id
